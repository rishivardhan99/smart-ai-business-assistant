# Replace with your actual Neon connection string. 
# Format: postgresql+psycopg://user:password@host/dbname
DATABASE_URL=postgresql+psycopg://username:password@ep-cool-darkness-123456.us-east-2.aws.neon.tech/neondb

# ------------------------------------------------------------------------------
# AI Provider Configuration
# ------------------------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# ------------------------------------------------------------------------------
# Google Sheets & CRM Integration
# ------------------------------------------------------------------------------
# The ID found in your Sheet URL: /d/[THIS_LONG_ID]/edit
GOOGLE_SHEET_ID=1RVILscE5JTpfSC2VSHaEt1787118XtVdGBV9PFqserw

# The name of your service account file in the /backend folder
GOOGLE_APPLICATION_CREDENTIALS=service_account.json

# ------------------------------------------------------------------------------
# Backend Configuration
# ------------------------------------------------------------------------------
PROJECT_NAME="Smart AI Business Assistant"
API_V1_STR="/api/v1"

# Origins allowed to access the API (Frontend URLs)
BACKEND_CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000"]

# ------------------------------------------------------------------------------
# Authentication (JWT)
# ------------------------------------------------------------------------------
# Generate a secure key using: openssl rand -hex 32
SECRET_KEY=your_super_secret_key_change_in_production
ACCESS_TOKEN_EXPIRE_MINUTES=1440 # 24 hours