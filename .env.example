# ------------------------------------------------------------------------------
# PostgreSQL Database Configuration
# ------------------------------------------------------------------------------
# Example Neon connection string provided by user: psql 'postgresql://neondb_own...'
# To use it, remove the "psql '" part at the beginning and the "'" at the end.
# Ensure you are using psycopg driver or asyncpg driver. We will use asyncpg or psycopg.
# For SQLAlchemy with psycopg (psycopg 3):
DATABASE_URL=postgresql+psycopg://username:password@ep-cool-darkness-123456.us-east-2.aws.neon.tech/neondb

# ------------------------------------------------------------------------------
# AI Provider Configuration
# ------------------------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# ------------------------------------------------------------------------------
# Backend Configuration
# ------------------------------------------------------------------------------
PROJECT_NAME="Smart AI Business Assistant"
API_V1_STR="/api/v1"
BACKEND_CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000"] # React/Vite default ports

# ------------------------------------------------------------------------------
# Authentication (JWT)
# ------------------------------------------------------------------------------
SECRET_KEY=your_super_secret_key_change_in_production
ACCESS_TOKEN_EXPIRE_MINUTES=1440 # 24 hours
